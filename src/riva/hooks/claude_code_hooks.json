{
  "_comment": "Reference only. Actual hooks are generated by 'riva hooks install' with the absolute Python path from sys.executable. Do not copy this file directly into ~/.claude/settings.json.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/python3 -m riva.hooks.hook claude-code SessionStart 2>/dev/null || true",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/python3 -m riva.hooks.hook claude-code PreToolUse 2>/dev/null || true",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/python3 -m riva.hooks.hook claude-code PostToolUse 2>/dev/null || true",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/python3 -m riva.hooks.hook claude-code SubagentStop 2>/dev/null || true",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/python3 -m riva.hooks.hook claude-code Stop 2>/dev/null || true",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
